{
  "name": "catdancer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "猫が見て楽しむWebアプリ（PixiJS v8 + Vite + TypeScript）",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
